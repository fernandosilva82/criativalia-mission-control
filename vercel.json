{
  "version": 2,
  "name": "criativalia-control-plane",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://disclosure-emphasis-costs-heights.trycloudflare.com/api/:path*"
    },
    {
      "source": "/health",
      "destination": "https://disclosure-emphasis-costs-heights.trycloudflare.com/api/stats"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
