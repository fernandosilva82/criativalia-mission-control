# WhatsApp Evolution API - Anti-Block Config

# API Settings
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=sua_api_key_aqui
INSTANCE_NAME=criativalia-bot

# Anti-Block Settings
DELAY_MIN_MS=3000
DELAY_MAX_MS=8000
MESSAGES_PER_HOUR_MAX=30
DAILY_LIMIT=200

# Randomization
RANDOMIZE_TIMING=true
RANDOMIZE_MESSAGE=true

# Cooldown Settings
COOLDOWN_AFTER_MESSAGES=10
COOLDOWN_DURATION_MINUTES=15

# Business Hours Only
BUSINESS_HOURS_ONLY=true
START_HOUR=9
END_HOUR=18

# Phone Number Rotation (if using multiple instances)
ROTATE_INSTANCES=false
INSTANCE_LIST=
