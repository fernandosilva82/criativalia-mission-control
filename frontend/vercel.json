{
  "version": 2,
  "name": "criativalia-control-plane",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://criativalia-runtime.railway.app/api/:path*"
    },
    {
      "source": "/health",
      "destination": "https://criativalia-runtime.railway.app/health"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://criativalia-runtime.railway.app/api/$1"
    },
    {
      "src": "/health",
      "dest": "https://criativalia-runtime.railway.app/health"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
