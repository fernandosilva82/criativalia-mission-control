# Central de Disparos WhatsApp
# Infraestrutura dedicada e isolada

NODE_ENV=production
PORT=3000

# Evolution API
EVOLUTION_API_URL=http://evolution-api:8080
EVOLUTION_API_KEY=central_disparos_secure_key_2024

# Database
DATABASE_URL=sqlite:///data/central.db

# Redis (para filas)
REDIS_URL=redis://redis:6379

# Anti-Block Settings
DELAY_MIN_MS=5000
DELAY_MAX_MS=12000
MESSAGES_PER_HOUR_MAX=25
DAILY_LIMIT_PER_NUMBER=150
COOLDOWN_AFTER_MESSAGES=8
COOLDOWN_DURATION_MINUTES=20

# Business Hours
BUSINESS_HOURS_ONLY=true
BUSINESS_START_HOUR=9
BUSINESS_END_HOUR=18
BUSINESS_TIMEZONE=America/Sao_Paulo

# Safety
MAX_RETRIES=3
RETRY_DELAY_MS=60000
PAUSE_ON_ERROR=true
