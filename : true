:!/bin/bash
# Buscar runs recentes do GitHub Actions
curl -s -H "Accept: application/vnd.github+json" \
  "https://api.github.com/repos/fernandosilva82/criativalia-mission-control/actions/runs?per_page=10" > /tmp/github_runs.json

echo "=== WORKFLOWS RECENTES ===" 
jq -r '.workflow_runs[] | "\(.id) | \(.name) | \(.status) | \(.conclusion // "null") | \(.created_at)"' /tmp/github_runs.json
