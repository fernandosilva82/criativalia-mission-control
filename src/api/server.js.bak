    </main>
  </div>

  <script>
    function showView(view) {
      document.querySelectorAll('.view').forEach(v=>v.classList.remove('active'));
      document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
      document.getElementById('view-'+view).classList.add('active');
      event.target.classList.add('active');
      if(view==='dashboard')loadDashboard();
      if(view==='timesheet')loadTimesheet();
      if(view==='kanban')loadKanban();
      if(view==='finance')loadFinance();
      if(view==='agents')loadAgents();
      if(view==='events')loadEvents();
    }
    
    function formatCurrency(val) {
      return 'R$ ' + val.toLocaleString('pt-BR', {minimumFractionDigits: 2, maximumFractionDigits: 2});
    }
    
    function formatVar(val) {
      const color = val >= 0 ? 'text-green-400' : 'text-red-400';
      const arrow = val >= 0 ? '↑' : '↓';
      return '<span class="' + color + '">' + arrow + ' ' + Math.abs(val).toFixed(1) + '%</span>';
    }
    
    async function loadDashboard() {
      const data = await (await fetch('/api/stats')).json();
      document.getElementById('stat-agents').textContent = data.runtime.agents ? data.runtime.agents.filter(a=>a.status==='running').length : 0;
      document.getElementById('stat-tasks').textContent = data.database.tasks.count;
      document.getElementById('stat-events').textContent = data.database.events_24h.count;
      document.getElementById('stat-opp').textContent = data.database.opportunities.count;
      document.getElementById('runtime-status').innerHTML = `
        <div class="grid grid-cols-2 gap-4">
          <div><p class="text-gray-500">Status</p><p class="text-xl font-bold">${data.runtime.isRunning?'<span class="text-green-400">● Running</span>':'<span class="text-gray-400">○ Stopped</span>'}</p></div>
          <div><p class="text-gray-500">Ticks</p><p class="text-xl font-bold">${data.runtime.tickCount}</p></div>
          <div><p class="text-gray-500">Night Mode</p><p class="text-xl font-bold">${data.runtime.nightMode?'🌙 On':'☀️ Off'}</p></div>
        </div>
      `;
    }
    
    async function loadTimesheet() {
      const data = await (await fetch('/api/timesheet/visual')).json();
      
      document.getElementById('ts-date').textContent = `Data: ${data.summary.date}`;
      document.getElementById('ts-total').textContent = data.summary.total_agents;
      document.getElementById('ts-active').textContent = data.summary.active_now;
      document.getElementById('ts-idle').textContent = data.summary.idle_now;
      document.getElementById('ts-hour').textContent = `${data.summary.current_hour}h`;
      
      // Generate header
      const headerRow = document.getElementById('ts-header');
      headerRow.innerHTML = '<th class="text-left p-2 sticky left-0 bg-gray-900">Agente</th>';
      for (let h = 0; h < 24; h++) {
        const isCurrent = h === data.summary.current_hour;
        headerRow.innerHTML += `<th class="p-2 text-center w-8 ${isCurrent ? 'accent-bg text-white' : 'text-gray-500'}">${h}h</th>`;
      }
      
      const tbody = document.getElementById('ts-grid');
      tbody.innerHTML = '';
      
      for (const [agentId, data_] of Object.entries(data.grid)) {
        const row = document.createElement('tr');
        row.className = 'border-b border-gray-800';
        
        // Agent name cell
        const nameCell = document.createElement('td');
        nameCell.className = 'p-2 sticky left-0 bg-gray-900 font-medium';
        nameCell.innerHTML = `
          <div class="flex items-center gap-2">
            <span class="w-2 h-2 rounded-full ${data_.agent.status === 'running' ? 'bg-green-500' : 'bg-gray-500'}"></span>
            ${data_.agent.name}
          </div>
        `;
        row.appendChild(nameCell);
        
        // Hour cells
        data_.hours.forEach(h => {
          const cell = document.createElement('td');
          cell.className = 'p-1 text-center';
          
          let bgClass = 'bg-gray-800';
          let title = 'Sem atividade';
          
          if (h.is_current) {
            if (h.is_idle) {
              bgClass = 'bg-yellow-500/20 border border-yellow-500';
              title = `Ocioso há ${h.idle_minutes} min`;
            } else if (h.activity === 'working') {
              bgClass = 'bg-green-500/20 border border-green-500';
              title = h.description || 'Trabalhando';
            } else if (h.activity === 'maintenance') {
              bgClass = 'bg-blue-500/20 border border-blue-500';
              title = 'Manutenção';
            }
          } else if (h.activity) {
            if (h.activity === 'working') bgClass = 'bg-green-900/30';
            else if (h.activity === 'maintenance') bgClass = 'bg-blue-900/30';
            else if (h.activity === 'idle') bgClass = 'bg-yellow-900/30';
          }
          
          cell.innerHTML = `<div class="w-6 h-6 rounded ${bgClass} mx-auto cursor-pointer" title="${title}"></div>`;
          row.appendChild(cell);
        });
        
        tbody.appendChild(row);
      }
    }
    
    async function loadKanban() {
      const data = await (await fetch('/api/kanban/macro')).json();
      const cols = data.columns;
      const stats = data.stats;
      
      // Update stats
      document.getElementById('kb-total').textContent = stats.total;
      document.getElementById('kb-p0').textContent = stats.by_priority.p0;
      document.getElementById('kb-p1').textContent = stats.by_priority.p1;
      document.getElementById('kb-p2').textContent = stats.by_priority.p2;
      
      // Update columns
      for (const [col, tasks] of Object.entries(cols)) {
        document.getElementById(`kb-count-${col}`).textContent = tasks.length;
        document.getElementById(`kb-col-${col}`).innerHTML = tasks.map(t => `
          <div class="kanban-card group">
            <div class="flex justify-between items-start mb-2">
              <p class="font-medium text-sm flex-1">${t.title}</p>
              <span class="text-xs px-2 py-0.5 rounded ${t.priority===0?'bg-red-500/20 text-red-400':t.priority===1?'bg-yellow-500/20 text-yellow-400':'bg-gray-600/20 text-gray-400'}">P${t.priority}</span>
            </div>
            <div class="flex gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
              <button onclick="updatePriority('${t.id}', 0)" class="text-xs px-2 py-1 bg-red-600 rounded" title="P0">P0</button>
              <button onclick="updatePriority('${t.id}', 1)" class="text-xs px-2 py-1 bg-yellow-600 rounded" title="P1">P1</button>
              <button onclick="updatePriority('${t.id}', 2)" class="text-xs px-2 py-1 bg-gray-600 rounded" title="P2">P2</button>
            </div>
          </div>
        `).join('');
      }
    }
    
    async function updatePriority(taskId, priority) {
      await fetch(`/api/tasks/${taskId}/priority`, {
        method: 'PUT',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({priority})
      });
      loadKanban();
    }
    
    async function loadFinance() {
      const data = await (await fetch('/api/finance/summary')).json();
      
      // KPIs
      document.getElementById('fin-gross-mtd').textContent = formatCurrency(data.mtd.gross);
      document.getElementById('fin-gross-mtd-var').innerHTML = formatVar(data.variations.mom);
      
      document.getElementById('fin-net-mtd').textContent = formatCurrency(data.mtd.net);
      document.getElementById('fin-net-mtd-var').innerHTML = formatVar(data.variations.mom);
      
      document.getElementById('fin-aov').textContent = formatCurrency(data.metrics.aov);
      document.getElementById('fin-orders-mtd').textContent = data.mtd.orders;
      document.getElementById('fin-orders-mtd-var').innerHTML = formatVar(data.variations.mom);
      
      // MoM
      document.getElementById('fin-mom-current').textContent = formatCurrency(data.mtd.gross);
      document.getElementById('fin-mom-previous').textContent = formatCurrency(data.previous_month.gross);
      document.getElementById('fin-mom-var').innerHTML = formatVar(data.variations.mom);
      
      // YoY
      document.getElementById('fin-yoy-current').textContent = formatCurrency(data.ytd.gross);
      document.getElementById('fin-yoy-previous').textContent = formatCurrency(data.previous_ytd.gross);
      document.getElementById('fin-yoy-growth').innerHTML = formatVar(data.variations.yoy);
      
      // Details
      document.getElementById('fin-items-mtd').textContent = data.mtd.items;
      document.getElementById('fin-items-per-order').textContent = data.metrics.items_per_order.toFixed(1);
      document.getElementById('fin-conversion').textContent = data.metrics.conversion_rate.toFixed(1) + '%';
      document.getElementById('fin-rev-per-day').textContent = formatCurrency(data.mtd.gross / data.mtd.days_in_month);
    }
    
    async function loadAgents() {
      const agents = await (await fetch('/api/agents')).json();
      document.getElementById('agents-list').innerHTML = agents.map(a=>`
        <div class="card mb-3 flex justify-between items-center">
          <div><p class="font-semibold">${a.name}</p><p class="text-sm text-gray-500">${a.role}</p></div>
          <span class="${a.status==='running'?'text-green-400':'text-gray-400'}">${a.status==='running'?'● Running':'○ Idle'}</span>
        </div>
      `).join('');
    }
    
    async function loadEvents() {
      const events = await (await fetch('/api/events?limit=50')).json();
      document.getElementById('events-list').innerHTML = events.map(e=>`
        <div class="card mb-2"><p class="font-medium">${e.message}</p><p class="text-sm text-gray-500">${e.type} • ${new Date(e.timestamp).toLocaleString()}</p></div>
      `).join('');
    }
    
    setInterval(()=>{
      if(document.getElementById('view-dashboard').classList.contains('active'))loadDashboard();
      if(document.getElementById('view-timesheet').classList.contains('active'))loadTimesheet();
      if(document.getElementById('view-kanban').classList.contains('active'))loadKanban();
    },5000);
    loadDashboard();
  </script>
</body></html>
`;
