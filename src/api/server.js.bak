import express from 'express';
import { orchestrator } from '../orchestrator/runtime.js';
import { randomUUID } from 'crypto';

const app = express();
const PORT = process.env.PORT || 3000;

app.use(express.json());

// CORS
app.use((req, res, next) => {
  res.header('Access-Control-Allow-Origin', '*');
  res.header('Access-Control-Allow-Methods', 'GET, POST, PUT, DELETE');
  res.header('Access-Control-Allow-Headers', 'Content-Type');
  next();
});

// Helper to get DB
const getDB = () => globalThis.runtimeDB;

// === STATS ===
app.get('/api/stats', (req, res) => {
  res.json({
    runtime: orchestrator.getState(),
    database: getDB().getStats()
  });
});

// === AGENTS ===
app.get('/api/agents', (req, res) => {
  res.json(getDB().getAgents());
});

app.get('/api/agents/:id', (req, res) => {
  const agent = getDB().getAgent(req.params.id);
  if (!agent) return res.status(404).json({ error: 'Not found' });
  res.json({ ...agent, tasks: getDB().getTasks({ agent_id: req.params.id }) });
});

// === TASKS ===
app.get('/api/tasks', (req, res) => {
  const filters = {};
  if (req.query.status) filters.status = req.query.status;
  if (req.query.agent_id) filters.agent_id = req.query.agent_id;
  if (req.query.priority) filters.priority = parseInt(req.query.priority);
  if (req.query.kanban_column) filters.kanban_column = req.query.kanban_column;
  res.json(getDB().getTasks(filters));
});

app.post('/api/tasks', (req, res) => {
  const { title, description, agent_id, priority = 1 } = req.body;
  const id = randomUUID();
  
  getDB().createTask({
    id, title, description, agent_id, priority,
    status: 'backlog', kanban_column: 'backlog',
    source: 'manual', created_at: new Date().toISOString()
  });
  
  getDB().logEvent({ type: 'task_create', message: `Created: ${title}`, severity: 'info' });
  res.status(201).json({ id, success: true });
});

// === KANBAN ===
app.get('/api/kanban', (req, res) => {
  const db = getDB();
  res.json({
    backlog: db.getTasks({ kanban_column: 'backlog' }),
    todo: db.getTasks({ kanban_column: 'todo' }),
    in_progress: db.getTasks({ kanban_column: 'in_progress' }),
    review: db.getTasks({ kanban_column: 'review' }),
    done: db.getTasks({ kanban_column: 'done' })
  });
});

app.put('/api/tasks/:id/kanban', (req, res) => {
  getDB().moveTaskKanban(req.params.id, req.body.column);
  res.json({ success: true });
});

// === EVENTS ===
app.get('/api/events', (req, res) => {
  res.json(getDB().getEvents(parseInt(req.query.limit) || 100));
});

// === TIMESHEET ===
app.get('/api/timesheet', (req, res) => {
  const date = req.query.date || new Date().toISOString().split('T')[0];
  res.json(getDB().getTimesheet(date, req.query.agent_id));
});

app.get('/api/timesheet/24h', (req, res) => {
  res.json(getDB().getLast24Hours());
});

// === TIMESHEET VISUAL (Agenda do Dia) ===
app.get('/api/timesheet/visual', (req, res) => {
  const db = getDB();
  const date = req.query.date || new Date().toISOString().split('T')[0];
  
  const agents = db.getAgents();
  const timesheet = db.getTimesheet(date);
  const tasks = db.getTasks({ status: 'in_progress' });
  
  // Build visual grid: agents x 24 hours
  const grid = {};
  const now = new Date();
  const currentHour = now.getHours();
  
  agents.forEach(agent => {
    grid[agent.id] = {
      agent: {
        id: agent.id,
        name: agent.name,
        status: agent.status
      },
      hours: Array(24).fill(null).map((_, hour) => {
        // Find activity for this hour
        const activity = timesheet.find(t => 
          t.agent_id === agent.id && t.hour_slot === hour
        );
        
        // Find current task
        const currentTask = tasks.find(t => t.agent_id === agent.id);
        const isCurrentHour = hour === currentHour;
        const isIdle = agent.status !== 'running' && isCurrentHour;
        
        // Calculate idle time
        let idleMinutes = 0;
        if (isIdle && agent.last_active) {
          const lastActive = new Date(agent.last_active);
          idleMinutes = Math.floor((now - lastActive) / 60000);
        }
        
        return {
          hour,
          activity: activity?.activity_type || (isCurrentHour ? (currentTask ? 'working' : 'idle') : null),
          description: activity?.description || (currentTask ? currentTask.title : null),
          task_id: activity?.task_id || (currentTask ? currentTask.id : null),
          is_current: isCurrentHour,
          is_idle: isIdle,
          idle_minutes: isCurrentHour ? idleMinutes : 0
        };
      })
    };
  });
  
  // Calculate summary
  const summary = {
    total_agents: agents.length,
    active_now: agents.filter(a => a.status === 'running').length,
    idle_now: agents.filter(a => a.status !== 'running').length,
    current_hour: currentHour,
    date
  };
  
  res.json({ grid, summary, timesheet });
});

// === KANBAN MACRO (sem agrupamento por agente) ===
app.get('/api/kanban/macro', (req, res) => {
  const db = getDB();
  const tasks = db.getTasks();
  
  // Group by kanban column
  const columns = {
    backlog: tasks.filter(t => t.kanban_column === 'backlog' || !t.kanban_column),
    todo: tasks.filter(t => t.kanban_column === 'todo'),
    in_progress: tasks.filter(t => t.kanban_column === 'in_progress'),
    review: tasks.filter(t => t.kanban_column === 'review'),
    done: tasks.filter(t => t.kanban_column === 'done')
  };
  
  // Sort by priority within each column
  for (const col in columns) {
    columns[col].sort((a, b) => a.priority - b.priority);
  }
  
  // Summary stats
  const stats = {
    total: tasks.length,
    by_priority: {
      p0: tasks.filter(t => t.priority === 0).length,
      p1: tasks.filter(t => t.priority === 1).length,
      p2: tasks.filter(t => t.priority === 2).length
    },
    by_column: {
      backlog: columns.backlog.length,
      todo: columns.todo.length,
      in_progress: columns.in_progress.length,
      review: columns.review.length,
      done: columns.done.length
    }
  };
  
  res.json({ columns, stats });
});

// === UPDATE TASK PRIORITY ===
app.put('/api/tasks/:id/priority', (req, res) => {
  const { priority } = req.body;
  if (priority === undefined || priority < 0 || priority > 2) {
    return res.status(400).json({ error: 'Priority must be 0 (P0), 1 (P1), or 2 (P2)' });
  }
  
  getDB().updateTask(req.params.id, { priority });
  getDB().logEvent({
    type: 'task_update',
    task_id: req.params.id,
    message: `Priority changed to P${priority}`,
    severity: 'info'
  });
  
  res.json({ success: true, priority });
});

// === FINANCEIRO ===
app.get('/api/finance/summary', (req, res) => {
  // Simulated data - would integrate with Shopify API
  const now = new Date();
  const currentMonth = now.getMonth();
  const currentYear = now.getFullYear();
  
  // Mock data based on Criativalia metrics
  const data = {
    mtd: {
      gross: 19780.84,
      net: 15824.67, // ~20% costs deducted
      orders: 59,
      items: 118,
      days_in_month: now.getDate(),
      days_total: new Date(currentYear, currentMonth + 1, 0).getDate()
    },
    previous_month: {
      gross: 15234.50,
      net: 12187.60,
      orders: 48,
      items: 96
    },
    ytd: {
      gross: 156432.18,
      net: 125145.74,
      orders: 467,
      items: 934
    },
    previous_ytd: {
      gross: 128765.32,
      net: 103012.26,
      orders: 385,
      items: 770
    },
    metrics: {
      aov: 335.27,
      items_per_order: 2.0,
      conversion_rate: 2.8
    }
  };
  
  // Calculate variations
  const momVar = ((data.mtd.gross - data.previous_month.gross) / data.previous_month.gross * 100).toFixed(1);
  const yoyGrowth = ((data.ytd.gross - data.previous_ytd.gross) / data.previous_ytd.gross * 100).toFixed(1);
  
  res.json({
    ...data,
    variations: {
      mom: parseFloat(momVar),
      yoy: parseFloat(yoyGrowth)
    }
  });
});

// === OPPORTUNITIES ===
app.get('/api/opportunities', (req, res) => {
  res.json(getDB().getOpportunities(req.query.status || 'open'));
});

// === DECISIONS ===
app.get('/api/decisions', (req, res) => {
  res.json(getDB().getPendingDecisions());
});

// === RUNTIME CONTROL ===
app.post('/api/runtime/start', async (req, res) => {
  await orchestrator.start();
  res.json({ status: 'started' });
});

app.post('/api/runtime/stop', (req, res) => {
  orchestrator.stop();
  res.json({ status: 'stopped' });
});

app.get('/api/runtime/state', (req, res) => {
  res.json(orchestrator.getState());
});

// === CONTROL PLANE UI ===
app.get('/', (req, res) => {
  res.send(ControlPlaneHTML);
});

app.listen(PORT, () => {
  console.log(`🌐 Server running on port ${PORT}`);
});

